  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.13.2",
    "dotenv": "17.4.2",
    "eslint": "10.6.0",
    "eslint-plugin-n": "18.2.1",
    "prettier": "3.9.4",
    "tsx": "4.22.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1"
  }
