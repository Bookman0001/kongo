  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.12.4",
    "dotenv": "17.4.2",
    "eslint": "10.4.0",
    "eslint-plugin-n": "18.0.1",
    "prettier": "3.8.3",
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.4"
